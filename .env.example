# Development environment (Worker origin only — do not append /api)
NEXT_PUBLIC_API_URL=http://localhost:8686
NEXT_PUBLIC_REMOTE_PATTERNS=https://r2.catcat.li

# Optional: used by app/api/config at build time when NEXT_PUBLIC_API_URL is not set (same value as Worker URL)
# API_URL=https://your-worker.workers.dev

# Production environment for Netlify
# Set these in Netlify dashboard: Site settings > Environment variables
# NEXT_PUBLIC_API_URL=https://your-backend-url.com
# NEXT_PUBLIC_REMOTE_PATTERNS=your-backend-url.com
